{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/luigisaetta/a2a-procurement-agents/specs/schemas/supplier-bid-request.schema.json",
  "title": "SupplierBidRequest",
  "description": "Supplier-facing request payload generated by the Bid Collection Agent for a single supplier and a single requested procurement part.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "bid_request_id",
    "supplier",
    "part",
    "currency",
    "response_deadline"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier of the procurement request.",
      "examples": ["REQ-2026-0001"]
    },
    "bid_request_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier of the bid request sent to the supplier.",
      "examples": ["BIDREQ-REQ-2026-0001-PART-001-SUP-001"]
    },
    "supplier": {
      "$ref": "#/$defs/Supplier"
    },
    "part": {
      "$ref": "#/$defs/RequestedPart"
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "description": "Expected ISO 4217 currency code for the supplier offer.",
      "examples": ["EUR"]
    },
    "response_deadline": {
      "type": "string",
      "format": "date-time",
      "description": "Deadline for the supplier response, expressed as an ISO 8601 timestamp.",
      "examples": ["2026-05-29T12:00:00Z"]
    }
  },
  "$defs": {
    "Supplier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["supplier_id", "supplier_name", "api_endpoint"],
      "properties": {
        "supplier_id": {
          "type": "string",
          "minLength": 1,
          "description": "Unique identifier of the supplier.",
          "examples": ["SUP-001"]
        },
        "supplier_name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable supplier name.",
          "examples": ["Northern Industrial Supply"]
        },
        "api_endpoint": {
          "type": "string",
          "minLength": 1,
          "description": "Supplier API endpoint used by the supplier offer provider.",
          "examples": ["mock://suppliers/SUP-001/offers"]
        }
      }
    },
    "RequestedPart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "part_id",
        "plant_code",
        "material_code",
        "material_description",
        "quantity",
        "unit_of_measure",
        "required_delivery_date"
      ],
      "properties": {
        "part_id": {
          "type": "string",
          "minLength": 1,
          "description": "Unique identifier of the requested part within the procurement request.",
          "examples": ["PART-001"]
        },
        "plant_code": {
          "type": "string",
          "minLength": 1,
          "description": "Code of the plant, site, or business unit requesting the part.",
          "examples": ["PLANT-01"]
        },
        "material_code": {
          "type": "string",
          "minLength": 1,
          "description": "Internal code of the requested material or item.",
          "examples": ["MAT-12345"]
        },
        "material_description": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable description of the requested material.",
          "examples": ["Industrial pump replacement kit"]
        },
        "quantity": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Requested quantity of the part.",
          "examples": [10]
        },
        "unit_of_measure": {
          "type": "string",
          "minLength": 1,
          "description": "Unit of measure for the requested quantity.",
          "examples": ["EA"]
        },
        "required_delivery_date": {
          "type": "string",
          "format": "date",
          "description": "Requested delivery date for the part, expressed as an ISO 8601 date.",
          "examples": ["2026-06-15"]
        }
      }
    }
  }
}
