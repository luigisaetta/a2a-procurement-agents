FROM python:3.11-slim

ARG SERVICE_PATH
ARG MCP_MODULE

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV MCP_MODULE=${MCP_MODULE}

WORKDIR /app

COPY deployments/docker-compose/requirements.mcp.txt /tmp/requirements.mcp.txt
RUN pip install --no-cache-dir -r /tmp/requirements.mcp.txt

COPY ${SERVICE_PATH} /app/${SERVICE_PATH}

ENV PYTHONPATH=/app/${SERVICE_PATH}/src

CMD ["sh", "-c", "python -m ${MCP_MODULE} --host 0.0.0.0 --port ${PROCUREMENT_DATA_MCP_PORT:-8011} --path /mcp"]
