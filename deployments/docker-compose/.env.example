OCI_REGION=us-chicago-1
OCI_AUTH=API_KEY
OCI_MODEL_ID=openai.gpt-5
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..example
OCI_PROFILE=DEFAULT
OCI_CONFIG_DIR=/absolute/path/to/.oci

BID_COLLECTION_AGENT_PORT=8000
OFFER_EVALUATION_AGENT_PORT=8001
PURCHASE_ORDER_AGENT_PORT=8002
PROCUREMENT_ORCHESTRATOR_PORT=8003
CONVERSATIONAL_INTAKE_PORT=8012
CONVERSATIONAL_INTAKE_EXTRACTOR_MODE=llm
PROCUREMENT_INTAKE_UI_PORT=3000
PROCUREMENT_DATA_MCP_PORT=8011
PROCUREMENT_DATA_MCP_URL=http://procurement-data-mcp:8011/mcp
BID_COLLECTION_AGENT_URL=http://bid-collection-agent:8000
OFFER_EVALUATION_AGENT_URL=http://offer-evaluation-agent:8001
PURCHASE_ORDER_AGENT_URL=http://purchase-order-agent:8002
PROCUREMENT_ORCHESTRATOR_URL=http://procurement-orchestrator:8003
CONVERSATIONAL_INTAKE_BASE_URL=http://conversational-procurement-intake:8012
AGENT_API_KEY=change-me

PROCUREMENT_ORCHESTRATOR_TELEMETRY_ENABLED=false
BID_COLLECTION_AGENT_TELEMETRY_ENABLED=false
OFFER_EVALUATION_AGENT_TELEMETRY_ENABLED=false
PURCHASE_ORDER_AGENT_TELEMETRY_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_METRICS_EXPORTER=otlp
OTEL_TRACES_EXPORTER=otlp
OTEL_METRIC_EXPORT_INTERVAL=5000
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_PROMETHEUS_PORT=9464
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

MYSQL_PORT=3306
